# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Configuration
# Get these from your Supabase Project Settings > API
VITE_SUPABASE_URL="your-project-url.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# FFL API Configuration (e.g., FFLs.com or GunBroker)
VITE_FFL_API_KEY="your-ffl-api-key"

# Authorize.net Configuration (Firearm-friendly)
# Get these from your Authorize.net Dashboard > Account > API Login ID and Transaction Key
AUTHORIZENET_API_LOGIN_ID="your-api-login-id"
VITE_AUTHORIZENET_API_LOGIN_ID="your-api-login-id"
AUTHORIZENET_TRANSACTION_KEY="your-transaction-key"
VITE_AUTHORIZENET_CLIENT_KEY="your-public-client-key" # For Accept.js

# Stripe Configuration (Note: Stripe prohibits firearms)
STRIPE_SECRET_KEY="sk_test_..."
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Supabase Service Role Key (for server-side operations)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
